{
  "name": "astc-passport-map",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "data": "python3 scripts/parse_pdf.py && python3 scripts/geocode.py",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "fuse.js": "^7.0.0",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/google.maps": "^3.65.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "wrangler": "^4.107.0"
  }
}
